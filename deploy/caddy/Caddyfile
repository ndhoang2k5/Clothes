{
  # Email dùng cho Let's Encrypt (đổi nếu muốn)
  email admin@unbee.vn
}

# One domain: shop + admin + API
unbee.vn {
  encode zstd gzip

  # Forward everything to internal nginx "web" container
  reverse_proxy web:80
}

# Second website on same VPS (must be behind the same Caddy),
# so only ONE thing binds ports 80/443.
#
# IMPORTANT: `ranbee_web:80` is a placeholder service/container name.
# Point it to the other website's internal container:port after you attach it to the same Docker network.
ranbeevn.com {
  encode zstd gzip
  reverse_proxy ranbee_web:80
}

